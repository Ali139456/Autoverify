# ---- Site ----
# Public URL of the deployed site (used for Stripe redirects, SEO & sitemap)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Vehicle inspections (Base44) ----
# After Publish in Base44, paste your public *.base44.app URL here for 1:1 content.
# Leave blank to use the built-in native page (hero + services from Base44 preview).
NEXT_PUBLIC_BASE44_VEHICLE_INSPECTIONS_URL=

# ---- Stripe (payments) ----
# Leave blank to run in demo mode (reports unlock without payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Report price in cents and currency (default: 3495 AUD = $34.95)
REPORT_PRICE_CENTS=3495
REPORT_CURRENCY=aud

# ---- Autograb (vehicle data) ----
# Leave blank to use built-in demo vehicle data
AUTOGRAB_API_KEY=
AUTOGRAB_BASE_URL=https://api.autograb.com.au/v2

# ---- Ravin.ai (photo damage analysis) ----
# Leave blank to use built-in demo damage analysis
RAVIN_API_KEY=
RAVIN_BASE_URL=https://api.ravin.ai/v1
